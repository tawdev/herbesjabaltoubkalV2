generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Admin {
  id         Int      @id @default(autoincrement())
  username   String   @unique @db.VarChar(100)
  password   String   @db.VarChar(255)
  email      String?  @db.VarChar(255)
  created_at DateTime @default(now()) @db.Timestamp(0)

  @@map("admin")
}

model Contact {
  id          Int            @id @default(autoincrement())
  name        String         @db.VarChar(100)
  email       String         @db.VarChar(255)
  message     String         @db.Text
  status      ContactStatus? @default(new)
  admin_notes String?        @db.Text
  created_at  DateTime       @default(now()) @db.Timestamp(0)
  updated_at  DateTime       @default(now()) @db.Timestamp(0)

  @@map("contacts")
}

enum ContactStatus {
  new
  read
  replied
}

model Order {
  id           Int           @id @default(autoincrement())
  user_name    String        @db.VarChar(100)
  user_email   String        @db.VarChar(255)
  user_phone   String        @db.VarChar(50)
  user_address String        @db.Text
  total_price  Decimal       @db.Decimal(10, 2)
  status       OrderStatus?  @default(pending)
  created_at   DateTime      @default(now()) @db.Timestamp(0)
  updated_at   DateTime      @default(now()) @db.Timestamp(0)
  items        OrderItem[]

  @@map("orders")
}

enum OrderStatus {
  pending
  processing
  shipped
  delivered
  cancelled
}

model OrderItem {
  id         Int     @id @default(autoincrement())
  order_id   Int
  product_id Int
  quantity   Int
  price      Decimal @db.Decimal(10, 2)
  order      Order   @relation(fields: [order_id], references: [id], onDelete: Cascade)
  product    Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([order_id], map: "order_id")
  @@index([product_id], map: "product_id")
  @@map("order_items")
}

model Product {
  id             Int             @id @default(autoincrement())
  name           String          @db.VarChar(255)
  name_ar        String          @db.VarChar(255)
  price          Decimal         @db.Decimal(10, 2)
  weight         String          @db.VarChar(50)
  description    String?         @db.Text
  description_ar String?         @db.Text
  category       ProductCategory
  image          String          @db.VarChar(255)
  stock          Int?            @default(0)
  rating         Decimal?        @default(0.00) @db.Decimal(3, 2)
  best_seller    Int?            @default(0) @db.TinyInt
  promo          Int?            @default(0) @db.TinyInt
  promo_price    Decimal?        @db.Decimal(10, 2)
  origin_country String?         @db.VarChar(100)
  ingredients    String?         @db.Text
  benefits       String?         @db.Text
  usage_method   String?         @db.Text
  created_at     DateTime        @default(now()) @db.Timestamp(0)
  order_items    OrderItem[]
  reviews        Review[]

  @@map("products")
}

enum ProductCategory {
  spices
  herbs
  mixes
  ground
  whole
}

model Recipe {
  id             Int      @id @default(autoincrement())
  title          String   @db.VarChar(255)
  title_ar       String   @db.VarChar(255)
  description    String?  @db.Text
  description_ar String?  @db.Text
  image          String   @db.VarChar(255)
  ingredients    String   @db.Text
  ingredients_ar String   @db.Text
  steps          String   @db.Text
  steps_ar       String   @db.Text
  spices_used    String?  @db.Text
  cooking_time   String?  @db.VarChar(50)
  difficulty     String?  @db.VarChar(50)
  created_at     DateTime @default(now()) @db.Timestamp(0)

  @@map("recipes")
}

model Review {
  id         Int      @id @default(autoincrement())
  product_id Int
  user_name  String   @db.VarChar(100)
  rating     Int
  comment    String?  @db.Text
  created_at DateTime @default(now()) @db.Timestamp(0)
  product    Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([product_id], map: "product_id")
  @@map("reviews")
}
